# .gitignore

# Environment variables
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
PIPFILE.lock

# Virtual Environment
venv/
env/
ENV/
env.bak/
venv.bak/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*.swn
.DS_Store
*.sublime-project
*.sublime-workspace

# Data files (but keep the directory structure)
data/
!data/.gitkeep
logs/
!logs/.gitkeep

# Testing
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# OS
Thumbs.db
.DS_Store
*~

# IDE
.vscode/
.vscode/settings.json
.vscode/extensions.json

# Streamlit
.streamlit/
